@model eShopMVC.App.ViewModels.Product.EditProductViewModel
@using eShop.Domain.Entities.ProductData
@{
    ViewData["Title"] = "Редагування товару";
}

<div class="row pt-4 pb-3 align-items-center">
    <div class="col"><h2>Редагування товару</h2></div>
    <div class="col-auto">
        <a asp-action="Manage" class="btn btn-outline-secondary btn-sm">← Назад</a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Type" class="form-label"></label>
                    <select asp-for="Type" class="form-select"
                            asp-items="Html.GetEnumSelectList<ProductType>()">
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label"></label>
                    <select asp-for="CategoryId" class="form-select"
                            asp-items="Model.CategoryList">
                        <option value="">— Не вибрано —</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="BaseUnitId" class="form-label"></label>
                    <select asp-for="BaseUnitId" class="form-select"
                            asp-items="Model.UnitList">
                        <option value="">— Не вибрано —</option>
                    </select>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Зберегти зміни</button>
                <a asp-action="Manage" class="btn btn-outline-secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

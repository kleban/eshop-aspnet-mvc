@model eShopMVC.App.ViewModels.Product.ProductViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="row pt-4 pb-3 align-items-center">
    <div class="col">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Каталог</a></li>
                @if (!string.IsNullOrWhiteSpace(Model.CategoryName))
                {
                    <li class="breadcrumb-item">
                        <a asp-action="Index" asp-route-categoryId="@Model.CategoryId">@Model.CategoryName</a>
                    </li>
                }
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <h2>@Model.Name</h2>
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="text-muted">@Model.Description</p>
        }

        <dl class="row mt-3">
            <dt class="col-sm-4">Категорія</dt>
            <dd class="col-sm-8">@(Model.CategoryName ?? "—")</dd>
            <dt class="col-sm-4">Тип товару</dt>
            <dd class="col-sm-8">@Model.TypeDisplay</dd>
            @if (!string.IsNullOrWhiteSpace(Model.BaseUnitSymbol))
            {
                <dt class="col-sm-4">Одиниця виміру</dt>
                <dd class="col-sm-8">@Model.BaseUnitSymbol</dd>
            }
        </dl>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <div class="fs-3 fw-bold text-primary mb-3">@Model.Price.ToString("N2") грн</div>
                <button type="button" class="btn btn-success w-100" disabled>
                    🛒 Додати в кошик
                </button>
                <div class="text-muted small mt-2">Функція в розробці</div>
            </div>
        </div>

        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <div class="mt-3 d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">Редагувати</a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Видалити</a>
                }
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Назад до каталогу</a>
</div>

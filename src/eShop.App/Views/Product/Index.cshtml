@model eShopMVC.App.ViewModels.Product.ProductCatalogViewModel
@{
    ViewData["Title"] = "Каталог товарів";
}

<div class="row pt-4 pb-2 align-items-center">
    <div class="col">
        <h2>Каталог товарів</h2>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <div class="col-auto">
            <a asp-action="Manage" class="btn btn-outline-primary btn-sm">Управління товарами</a>
        </div>
    }
</div>

<div class="row mb-4 g-2 align-items-center">
    <div class="col-md-5">
        <form method="get" asp-action="Index" class="d-flex gap-2">
            <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
            <input type="search" name="search" value="@Model.Search"
                   class="form-control form-control-sm" placeholder="Пошук товарів..." />
            <button type="submit" class="btn btn-outline-secondary btn-sm">Знайти</button>
            @if (!string.IsNullOrWhiteSpace(Model.Search))
            {
                <a asp-action="Index" asp-route-categoryId="@Model.SelectedCategoryId"
                   class="btn btn-outline-danger btn-sm">✕</a>
            }
        </form>
    </div>
    <div class="col-auto">
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Index" class="btn btn-sm @(Model.SelectedCategoryId == null ? "btn-primary" : "btn-outline-secondary")">
                Всі
            </a>
            @foreach (var cat in Model.Categories)
            {
                <a asp-action="Index"
                   asp-route-categoryId="@cat.Id"
                   asp-route-search="@Model.Search"
                   class="btn btn-sm @(Model.SelectedCategoryId == cat.Id ? "btn-primary" : "btn-outline-secondary")">
                    @cat.Name
                </a>
            }
        </div>
    </div>
</div>

@if (!Model.Products.Any())
{
    <div class="alert alert-info">Товарів не знайдено.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var product in Model.Products)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-secondary mb-2 align-self-start">@product.CategoryName</span>
                        <h5 class="card-title">@product.Name</h5>
                        @if (!string.IsNullOrWhiteSpace(product.Description))
                        {
                            <p class="card-text text-muted small flex-grow-1">
                                @(product.Description.Length > 100
                                    ? product.Description[..100] + "…"
                                    : product.Description)
                            </p>
                        }
                        else
                        {
                            <div class="flex-grow-1"></div>
                        }
                        <div class="mt-3">
                            <span class="fs-5 fw-bold text-primary">@product.Price.ToString("N2") грн</span>
                        </div>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@product.Id"
                           class="btn btn-outline-secondary btn-sm">Деталі</a>
                        <button type="button" class="btn btn-success btn-sm ms-auto" disabled>
                            🛒 Додати в кошик
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

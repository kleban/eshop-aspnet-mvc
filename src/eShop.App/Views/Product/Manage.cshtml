@model IEnumerable<eShopMVC.App.ViewModels.Product.ProductViewModel>
@{
    ViewData["Title"] = "Управління товарами";
}

<div class="row pt-4 pb-3 align-items-center">
    <div class="col">
        <h2>Управління товарами</h2>
    </div>
    <div class="col-auto d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary btn-sm">+ Додати товар</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Каталог</a>
    </div>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show py-2">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Товарів ще немає.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Назва</th>
                    <th>Категорія</th>
                    <th>Тип</th>
                    <th class="text-end">Ціна, грн</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="text-muted small">@p.Id</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@p.Id" class="text-decoration-none fw-semibold">
                                @p.Name
                            </a>
                        </td>
                        <td>@(p.CategoryName ?? "—")</td>
                        <td><span class="badge bg-secondary">@p.TypeDisplay</span></td>
                        <td class="text-end fw-bold">@p.Price.ToString("N2")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@p.Id"
                               class="btn btn-outline-primary btn-sm">Редагувати</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@p.Id"
                                   class="btn btn-outline-danger btn-sm ms-1">Видалити</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

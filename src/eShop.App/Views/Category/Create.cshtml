@using eShop.Domain.Entities
@model CreateCategoryViewModel
@{
    Layout = "/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Категорії";
    ViewData["description"] = "Нова категорія";
    ViewData["keywords"] = "";
}

<!-- [ breadcrumb ] start -->
<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-12">
                <div class="page-header-title">
                    <h5 class="m-b-10">Sample Page</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="../dashboard/index.html">Home</a></li>
                    <li class="breadcrumb-item"><a href="javascript: void(0)">Other</a></li>
                    <li class="breadcrumb-item" aria-current="page">Sample Page</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- [ Main Content ] start -->
<div class="row">
    <!-- [ sample-page ] start -->
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header">
                <a asp-controller="category" asp-action="index" class="btn btn-sm btn-outline-primary float-end">
                    <i class="bi bi-arrow-left">Back To List</i>
                </a>
                <h3>Нова категорія</h3>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="border p-3 p-4">
                        <div class="row">
                            @* <div asp-validation-summary="All" class="text-danger"></div> *@
                        </div>
                        <div class="row mb-3 p-1">
                            <label asp-for="Name" class="p-0"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="row mb-3 p-1">
                            <label asp-for="DisplayOrder" class="p-0"></label>
                            <input asp-for="DisplayOrder" class="form-control" />
                            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                        </div>
                        <div class="row">
                            <div class="col-6 col-md-3">
                                <button type="submit" class="btn btn-primary">Create</button>
                            </div>
                            <div class="col-6 col-md-3">
                                <a asp-controller="category" asp-action="index" class="btn btn-secondary border">Batck To List</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <!-- [ sample-page ] end -->
</div>
<!-- [ Main Content ] end -->





@section Scripts {
    @{
       <partial name="_ValidationScriptsPartial" />
    }
}
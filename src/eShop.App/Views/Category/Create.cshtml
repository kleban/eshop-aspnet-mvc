@using eShop.Domain.Entities
@model CreateCategoryViewModel

<div class="row pt-4 pb-23">
    <div class="col-6">
        <h2 class="text-primary">Нова категорія</h2>
    </div>
    <div class="col-6 text-end">
        <a asp-controller="category" asp-action="index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left">Back To List</i>
        </a>
    </div>
</div>

<form method="post">
    <div class="border p-3 p-4">
        <div class="row">   
            <div asp-validation-summary="All" class="text-danger"></div>
        </div>
        <div class="row mb-3 p-1">
            <label asp-for="Name" class="p-0"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="row mb-3 p-1">
            <label asp-for="DisplayOrder" class="p-0"></label>
            <input asp-for="DisplayOrder" class="form-control" />
            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
        </div>
        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-primary form-control">Create</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="category" asp-action="index" class="btn btn-secondary border form-control">Batck To List</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}
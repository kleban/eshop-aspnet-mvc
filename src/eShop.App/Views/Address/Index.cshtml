@model IEnumerable<eShopMVC.App.ViewModels.Address.AddressViewModel>
@{
    ViewData["Title"] = "Мої адреси";
}

<div class="page-header">
    <h1 class="page-title">Адреси доставки</h1>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Додати адресу</a>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        <span style="font-family:'Orbitron',sans-serif;font-size:0.75rem;letter-spacing:0.1em;">// ПОРОЖНЬО</span>
        <br />У вас ще немає збережених адрес доставки.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var address in Model)
        {
            <div class="col">
                <div class="card h-100 @(address.IsDefault ? "address-card-default" : "")">
                    <div class="card-body">
                        @if (address.IsDefault)
                        {
                            <span class="badge bg-primary mb-2">◉ Основна</span>
                        }
                        <h5 class="card-title" style="font-family:'Rajdhani',sans-serif;font-size:1rem;font-weight:700;letter-spacing:0.04em;">
                            @address.FirstName @address.LastName
                        </h5>
                        <p class="mb-1 small" style="color:var(--neon-cyan);font-family:'Rajdhani',sans-serif;letter-spacing:0.03em;">@address.PhoneNumber</p>
                        <p class="mb-1 small" style="color:var(--text-muted);">@address.AddressLine</p>
                        <p class="mb-1 small" style="color:var(--text-muted);">@address.PostalCode, @address.City@(!string.IsNullOrWhiteSpace(address.Region) ? $", {address.Region}" : "")</p>
                        <p class="mb-0 small" style="color:var(--text-dim);">@address.Country</p>
                    </div>
                    <div class="card-footer d-flex gap-2 align-items-center flex-wrap">
                        <a asp-action="Edit" asp-route-id="@address.Id" class="btn btn-sm btn-outline-secondary">Редагувати</a>
                        <a asp-action="Delete" asp-route-id="@address.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                        @if (!address.IsDefault)
                        {
                            <form asp-action="SetDefault" method="post" class="ms-auto">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@address.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">Зробити основною</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
